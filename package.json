{
  "name": "sound-cut-auto",
  "version": "0.4.2",
  "description": "Sound Cut Auto — desktop app that cuts silence out of video and exports to mp4, Premiere, FCP, DaVinci and more",
  "main": "out/main/index.js",
  "private": true,
  "author": "Umut Ozyildirim",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "fetch:cli": "node scripts/fetch-auto-editor.mjs",
    "fetch:ffmpeg": "node scripts/fetch-ffmpeg.mjs",
    "fetch:all": "npm run fetch:cli && npm run fetch:ffmpeg",
    "build:icons": "node scripts/build-icons.mjs",
    "prebuild:dist": "npm run fetch:all",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:win": "electron-vite build && electron-builder --win",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@radix-ui/react-collapsible": "^1.1.14",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.1.8",
    "cmdk": "^1.1.1",
    "cross-spawn": "^7.0.6",
    "electron-log": "^5.4.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^2.0.7",
    "tree-kill": "^1.2.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "postcss": "^8.5.1",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "to-ico": "^1.1.5",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
